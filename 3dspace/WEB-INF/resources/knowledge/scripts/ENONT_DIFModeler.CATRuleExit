	<!--DIFAnnotationSet-->

	<Script OpeningID="PLMImportExportAttributesValuation" Type="DIFAnnotationSet"    ScriptName="ENONT_PLMReference_BLInitialization" >
		<Condition Attribute="OperationId" Value="DataExchangeImport"/>
		<Condition Attribute="Policy" Value="VPLM_SMB_Definition" />
