{
    "dsili:IllustratedItem": {
        "create": {
            "onPremiseLimit": 50,
            "onCloudLimit": 1
        },
        "expand": {
            "maxPathCount": 10000,
            "defaultMask": "dsili:IllustratedItem.ExpandMask.Default",
            "implementationClass": "com.dassault_systemes.enovia.xapps.dsili.V1.implementations.dsiliExpandResultBuilderImpl"
        },
        "fetchall": {
            "onPremiseLimit": 1000,
            "onCloudLimit": 100
        }
    },
    "dsili:IllustratedItemInstance": {
        "create": {
            "onPremiseLimit": 10,
            "onCloudLimit": 1,
            "payloadEntryKey": "instances",
            "mandKeys": [
                [
                    {
                        "payloadKey": "referencedObject",
                        "crudKey": "TO_IDs",
                        "payloadType": "linkableObject"
                    },
                    {
                        "payloadKey": "URI_RootId",
                        "crudKey": "From_IDs",
                        "payloadType": "URI_RootId"
                    },
                    {
                        "payloadKey": "referencedObject",
                        "crudKey": "Type",
                        "payloadType": "Custom",
                        "implementationClass": "com.dassault_systemes.delmia.ppr.nav.procedures.corpus_decl.PayloadParser$FindInstanceTypeName"
                    }
                ]
            ]
        },
        "replace": {
            "onPremiseLimit": 10,
            "onCloudLimit": 1,
            "payloadEntryKey": "instances",
            "mandKeys": [
                [
                    {
                        "payloadKey": "referencedObject",
                        "crudKey": "TO_IDs",
                        "payloadType": "linkableObject"
                    },
                    {
                        "payloadKey": "URI_RootId",
                        "crudKey": "From_IDs",
                        "payloadType": "URI_RootId"
                    },
                    {
                        "payloadKey": "URI_ContentId",
                        "crudKey": "ID",
                        "payloadType": "URI_ContentId"
                    },
                    {
                        "payloadKey": "referencedObject",
                        "crudKey": "Type",
                        "payloadType": "Custom",
                        "implementationClass": "com.dassault_systemes.delmia.ppr.nav.procedures.corpus_decl.PayloadParser$FindInstanceTypeName"
                    }
                ]
            ]
        },
        "fetchall": {
            "onPremiseLimit": 100,
            "onCloudLimit": 100
        },
        "locate": {
            "indexLocateMaxLimit": 1000,
            "defaultMask": "dsili:IllustratedItemInstanceLocateMask",
            "navigateRules": [
                {
                    "navigateFrom": "from parent illustratedItem reference",
                    "filterKey": "source",
                    "pathToNavigate": [
                        {
                            "navigateToRel": {
                                "relTypes": [
                                    "PLMInstance"
                                ],
                                "mode": "stop_at_rel"
                            }
                        }
                    ]
                },
                {
                    "navigateFrom": "from child illustratedItem reference",
                    "filterKey": "target",
                    "pathToNavigate": [
                        {
                            "navigateFromRel": {
                                "relTypes": [
                                    "PLMInstance"
                                ],
                                "mode": "stop_at_rel"
                            }
                        }
                    ]
                }
            ]
        }
    },
    "dsili:ItemSpecification": {
        "create": {},
        "fetchall": {
            "onPremiseLimit": 10,
            "onCloudLimit": 10
        },
        "locate": {
            "indexLocateMaxLimit": 1000,
            "defaultMask": "dsili:ItemSpecificationLocateMask",
            "navigateRules": [
                {
                    "navigateFrom": "mfgitem",
                    "pathToNavigate": [
                        {
                            "navigateFromSR": {
                                "roles": [
                                    "52",
                                    "51"
                                ]
                            }
                        }
                    ]
                }
            ]
        }
    }
}
