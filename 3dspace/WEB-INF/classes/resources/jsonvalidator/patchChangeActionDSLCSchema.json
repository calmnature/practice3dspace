    "add": {
      "type": "array",
      "description": "Array of items to add",
      "items": {
        "type": "object",
        "description": "An item in the add array",
        "additionalProperties": true,
        "propertyNames": {
          "not": {
            "enum": [
              "prerequiredDependencies",
              "prerequiringDependencies",
              "corequiringDependencies"
            ]
          }
        }
      }
    },
    "remove": {
      "type": "array",
      "description": "Array of items to remove",
      "items": {
        "type": "object",
        "description": "An item in the remove array",
        "additionalProperties": true,
        "propertyNames": {
          "not": {
            "enum": [
              "prerequiredDependencies",
              "prerequiringDependencies",
              "corequiringDependencies"
            ]
          }
        }
      }
    }
  },
  "additionalProperties": true
}

