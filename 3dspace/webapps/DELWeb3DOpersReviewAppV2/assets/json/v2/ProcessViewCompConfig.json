                "module": "DELWebOERTableViewComp",
                "path": "icons/22/I_ExpandAll.png"
            },
            "availableOn": {
                "position": [
                    "root",
                    "intermediate"
                ]
            },
            "submenu": [
                {
                    "type": "WAfrDefaultHandlerItem",
                    "handlerId": "DELWebOERTableViewCompExpandAll"
                },
                {
                    "type": "WAfrDefaultHandlerItem",
                    "handlerId": "DELWebOERTableViewCompExpandNLevels"
                },
                {
                    "type": "WAfrDefaultHandlerItem",
                    "handlerId": "DELWebOERTableViewCompCollapseAll"
                }
            ]
        },
        {
            "handlerId": "DELWebOERTableViewCompFind",
            "type": "WAfrDefaultHandlerItem",
            "availableOn": {
                "position": [
                    "all"
                ]
            },
            "args": {
                "findInColumns": [
                    "PROCESS.Title",
                    "PROCESS.InstanceLabel",
                    "PROCESS.Revision",
                    "PROCESS.Description",
                    "PROCESS.Maturity"
                ]
            }
        },
        {
            "handlerId": "DELWebOERPropertiesPanelCmd",
            "type": "WAfrDefaultHandlerItem",
            "availableOn": {
                "position": [
                    "all"
                ]
            }
        },
        {
            "type": "PushItem",
            "identifier": "OpenWith",
            "availableOn": {
                "position": [
                    "all"
                ]
            }
        }
