#Prog TimeLimit_TSO_References (iPLMIDSet :  #In PLMIDSet,oPLMIDSet :  #Out PLMIDSet) : VoidType
  {
let PLMIDSetTimeLimitRef (PLMIDSet)
let PLMIDSetTimeLimitParam (PLMIDSet)

PLMIDSetTimeLimitRef = Restrict(iPLMIDSet, "DELTimeLimit/DELTimeLimitReferenceAbstract")

PLMIDSetTimeLimitParam = ExecutePLMProcedure( "TimeLimit_ExportAsDesign", PLMIDSetTimeLimitRef )

oPLMIDSet = PLMIDSetTimeLimitRef + PLMIDSetTimeLimitParam

}
