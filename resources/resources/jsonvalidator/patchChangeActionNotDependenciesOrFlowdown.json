{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title":"Check patch for dependencies or flowdown inclusion",
  "type": "object",
  "properties": {
    "add": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "propertyNames": {
          "not": {
            "enum": [
              "isFlowDownOf",
              "prerequiredDependencies",
              "prerequiringDependencies",
              "corequiringDependencies"
            ]
          }
        }
      }
    },
    "remove": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "propertyNames": {
          "not": {
            "enum": [
              "isFlowDownOf",
              "prerequiredDependencies",
              "prerequiringDependencies",
              "corequiringDependencies"
            ]
          }
        }
      }
    }
  },
  "additionalProperties": true
}

